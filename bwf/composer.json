{
    "name": "bramley/window-factory-cpq",
    "type": "project",
    "description": "Bramley Window Factory - Window & Door Pricing Engine, Configurator, CMS and Quotation System",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0",
        "barryvdh/laravel-dompdf": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "App\\": "app/", "Database\\Factories\\": "database/factories/", "Database\\Seeders\\": "database/seeders/" }
    },
    "scripts": {
        "post-root-package-install": [ "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"" ]
    },
    "config": { "optimize-autoloader": true, "preferred-install": "dist", "sort-packages": true },
    "minimum-stability": "stable",
    "prefer-stable": true
}
